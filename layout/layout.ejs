<%
// 获取主题配置
const config = theme;

// 确定页面类型
let page_type = 'index';
if (['post', 'page'].includes(page.layout)) {
  page_type = 'content';
}

// 获取主题偏好
const prefers_theme = config.style?.prefers_theme || 'auto';
const theme_attr = prefers_theme === 'auto' ? '' : `data-theme="${prefers_theme}"`;

// Pjax 配置
const pjaxEnabled = config.features?.pjax !== false;
%>
<!DOCTYPE html>
<html lang="<%= page.lang || config.language || 'en' %>" <%= theme_attr %>>
<head>
  <%- partial('_partial/head') %>
</head>
<body>
  <%# Loading 动画 %>
  <% if (config.features?.pjax) { %>
  <div class="loading-wrap">
    <div class="loading-animation">
      <div class="loading-dot"></div>
      <div class="loading-dot"></div>
      <div class="loading-dot"></div>
    </div>
  </div>
  <% } %>

  <div id="app" class="app-container">
    <!-- Header -->
    <%- partial('_partial/header') %>

    <!-- Main Content -->
    <main class="main-content" role="main">
      <div class="container">
        <!-- Breadcrumb -->
        <% if (page.layout !== 'index') { %>
          <%- partial('_partial/breadcrumb') %>
        <% } %>

        <div class="content-wrapper <%= page_type %>">
          <!-- Sidebar (Left) -->
          <% if (config.sidebar?.enable && config.sidebar?.position === 'left') { %>
            <%- partial('_partial/sidebar') %>
          <% } %>

          <!-- Main Article -->
          <article class="article-container">
            <%- body %>
          </article>

          <!-- Sidebar (Right) -->
          <% if (config.sidebar?.enable && config.sidebar?.position === 'right') { %>
            <%- partial('_partial/sidebar') %>
          <% } %>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <%- partial('_partial/footer') %>
  </div>

  <!-- Rightside Buttons -->
  <div id="rightside-config-hide">
    <% if (config.features?.back_to_top) { %>
      <button id="back-to-top" class="back-to-top" aria-label="Back to top">
        <svg viewBox="0 0 24 24" width="24" height="24">
          <path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" fill="currentColor"/>
        </svg>
      </button>
    <% } %>

    <% if (config.features?.reading_mode) { %>
      <button id="read-mode" class="read-mode" aria-label="Read mode">
        <svg viewBox="0 0 24 24" width="24" height="24">
          <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" fill="currentColor"/>
        </svg>
      </button>
    <% } %>
  </div>

  <!-- Scripts -->
  <%- partial('_partial/scripts') %>

  <!-- Custom Inject -->
  <% if (config.inject?.body_end) { %>
    <%- config.inject.body_end %>
  <% } %>
</body>
</html>
