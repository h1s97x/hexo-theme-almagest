<%
// Table of Contents Component
const config = theme;
const tocConfig = config.toc || {};
const position = tocConfig.position || 'right';
const title = tocConfig.title || __('toc');
%>

<aside class="toc-wrapper toc-<%= position %>">
  <div class="toc-header">
    <h3 class="toc-title">
      <svg class="icon" viewBox="0 0 24 24" width="18" height="18">
        <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" fill="currentColor"/>
      </svg>
      <%= title %>
    </h3>
    <% if (tocConfig.collapse) { %>
      <button class="toc-toggle" aria-label="Toggle TOC">
        <svg class="icon" viewBox="0 0 24 24" width="16" height="16">
          <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" fill="currentColor"/>
        </svg>
      </button>
    <% } %>
  </div>
  <div class="toc-content<%= tocConfig.collapse ? ' collapsible' : '' %>">
    <%- toc %>
  </div>
</aside>
