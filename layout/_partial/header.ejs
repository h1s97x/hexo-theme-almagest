<%
const config = theme;
%>

<header class="site-header">
  <div class="header-container">
    <!-- Logo -->
    <div class="logo">
      <a href="<%= url_for('/') %>" class="logo-link">
        <% if (config.style?.logo) { %>
          <img src="<%= url_for(config.style.logo) %>" alt="Logo" class="logo-img">
        <% } %>
        <span class="logo-text"><%= config.title %></span>
      </a>
    </div>

    <!-- Navigation -->
    <nav class="site-nav" id="site-nav">
      <% if (config.menu) { %>
        <% for (const [name, value] of Object.entries(config.menu)) { %>
          <% if (typeof value === 'string') { %>
            <!-- 单个菜单项 -->
            <a href="<%= url_for(value) %>" class="nav-link">
              <%= name %>
            </a>
          <% } else if (Array.isArray(value)) { %>
            <!-- 带子菜单的菜单项 -->
            <div class="nav-item has-sub">
              <a href="javascript:void(0);" class="nav-link">
                <%= name %>
                <svg class="sub-menu-icon" viewBox="0 0 24 24" width="12" height="12">
                  <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                </svg>
              </a>
              <div class="nav-submenu">
                <% value.forEach(item => { %>
                  <% const [subName, subPath] = Object.entries(item)[0]; %>
                  <a href="<%= url_for(subPath) %>" class="nav-submenu-item">
                    <%= subName %>
                  </a>
                <% }); %>
              </div>
            </div>
          <% } else if (typeof value === 'object' && value !== null) { %>
            <!-- 对象形式的子菜单 -->
            <div class="nav-item has-sub">
              <a href="<%= url_for(value.path || '#') %>" class="nav-link<%= value.submenu ? '' : '' %>">
                <%= name %>
                <% if (value.submenu) { %>
                  <svg class="sub-menu-icon" viewBox="0 0 24 24" width="12" height="12">
                    <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                  </svg>
                <% } %>
              </a>
              <% if (value.submenu) { %>
                <div class="nav-submenu">
                  <% value.submenu.forEach(item => { %>
                    <% const [subName, subPath] = Object.entries(item)[0]; %>
                    <a href="<%= url_for(subPath) %>" class="nav-submenu-item">
                      <%= subName %>
                    </a>
                  <% }); %>
                </div>
              <% } %>
            </div>
          <% } %>
        <% } %>
      <% } %>
    </nav>

    <!-- Right Actions -->
    <div class="header-actions">
      <!-- Search Button -->
      <% if (config.features?.search) { %>
        <button class="action-btn search-btn" id="search-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="M15.5 1h-8C6.12 1 5 2.12 5 3.5v17C5 21.88 6.12 23 7.5 23h8c1.38 0 2.5-1.12 2.5-2.5v-17C18 2.12 16.88 1 15.5 1zm-4 21c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4.5-4H7V4h9v14z" fill="currentColor"/>
          </svg>
        </button>
      <% } %>

      <!-- Theme Toggle Button -->
      <button class="action-btn theme-toggle-btn" id="theme-toggle" aria-label="Toggle theme">
        <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20">
          <path d="M12 18C8.68 18 6 15.32 6 12s2.68-6 6-6 6 2.68 6 6-2.68 6-6 6zm0-10c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zM13 2h-2v3h2V2zm0 15h-2v3h2v-3zM5 11H2v2h3v-2zm15 0h-3v2h3v-2zM6.3 5.3L4.22 3.22 2.81 4.63l2.07 2.07 1.42-1.41zM17.19 16.37l2.07 2.07 1.41-1.41-2.07-2.07-1.41 1.41zM16.37 6.3l1.41-1.41 2.07 2.07-1.41 1.41-2.07-2.07zM4.63 17.19l-2.07 2.07 1.41 1.41 2.07-2.07-1.41-1.41z" fill="currentColor"/>
        </svg>
        <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20">
          <path d="M9.37,5.51C9.69,5.56 10.01,5.59 10.34,5.59C14.77,5.59 18.41,9.23 18.41,13.66C18.41,14.69 18.22,15.67 17.87,16.58C17.45,15.15 16.97,13.71 16.6,12.24C16.31,11.04 16.07,9.91 15.84,8.7C15.55,7.05 15.27,5.4 15.03,3.72L15.03,3.13C15.03,2.6 14.61,2.15 14.08,2.15C13.56,2.15 13.15,2.6 13.15,3.13L13.15,5.3C12.54,5.27 11.92,5.25 11.31,5.25C9.92,5.25 8.54,5.36 7.18,5.59L7.18,3.13C7.18,2.6 6.77,2.15 6.24,2.15C5.72,2.15 5.3,2.6 5.3,3.13L5.3,3.72C5.07,5.4 4.78,7.05 4.5,8.7C4.27,9.91 4.03,11.04 3.74,12.24C3.37,13.71 2.89,15.15 2.47,16.58C2.12,15.67 1.93,14.69 1.93,13.66C1.93,9.23 5.57,5.59 10,5.59C10.17,5.59 10.34,5.59 10.5,5.6L9.37,5.51Z" fill="currentColor"/>
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button class="action-btn mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="20" height="20">
          <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu">
  <nav class="mobile-nav">
    <% if (config.menu) { %>
      <% for (const [name, value] of Object.entries(config.menu)) { %>
        <% if (typeof value === 'string') { %>
          <a href="<%= url_for(value) %>" class="mobile-nav-link">
            <%= name %>
          </a>
        <% } else if (Array.isArray(value)) { %>
          <!-- 带子菜单的菜单项 -->
          <div class="mobile-nav-item has-sub">
            <a href="javascript:void(0);" class="mobile-nav-link mobile-nav-parent">
              <%= name %>
              <svg class="sub-menu-icon" viewBox="0 0 24 24" width="16" height="16">
                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
              </svg>
            </a>
            <div class="mobile-nav-submenu">
              <% value.forEach(item => { %>
                <% const [subName, subPath] = Object.entries(item)[0]; %>
                <a href="<%= url_for(subPath) %>" class="mobile-nav-submenu-item">
                  <%= subName %>
                </a>
              <% }); %>
            </div>
          </div>
        <% } else if (typeof value === 'object' && value !== null) { %>
          <div class="mobile-nav-item has-sub">
            <a href="<%= url_for(value.path || '#') %>" class="mobile-nav-link mobile-nav-parent">
              <%= name %>
              <% if (value.submenu) { %>
                <svg class="sub-menu-icon" viewBox="0 0 24 24" width="16" height="16">
                  <path d="M7 10l5 5 5-5z" fill="currentColor"/>
                </svg>
              <% } %>
            </a>
            <% if (value.submenu) { %>
              <div class="mobile-nav-submenu">
                <% value.submenu.forEach(item => { %>
                  <% const [subName, subPath] = Object.entries(item)[0]; %>
                  <a href="<%= url_for(subPath) %>" class="mobile-nav-submenu-item">
                    <%= subName %>
                  </a>
                <% }); %>
              </div>
            <% } %>
          </div>
        <% } %>
      <% } %>
    <% } %>
  </nav>
</div>
