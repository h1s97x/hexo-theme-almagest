<%
// 文章卡片组件
const config = theme;
const post_image = post.cover || post.photos?.[0] || null;
const excerpt = post.excerpt || strip_html(post.content)?.substring(0, config.article?.excerpt_length || 200);
%>

<article class="post-card">
  <% if (post_image) { %>
    <div class="post-card-image">
      <img src="<%= url_for(post_image) %>" alt="<%= post.title %>" loading="lazy" />
    </div>
  <% } %>
  
  <div class="post-card-content">
    <% if (post.categories && post.categories.length > 0) { %>
      <div class="post-card-category">
        <a href="<%= url_for(post.categories.toArray()[0].path) %>">
          <%= post.categories.toArray()[0].name %>
        </a>
      </div>
    <% } %>
    
    <h2 class="post-card-title">
      <a href="<%= url_for(post.path) %>"><%= post.title %></a>
    </h2>
    
    <% if (excerpt) { %>
      <p class="post-card-excerpt"><%= excerpt %>...</p>
    <% } %>
    
    <div class="post-card-meta">
      <span class="meta-item">
        <svg viewBox="0 0 24 24" width="14" height="14">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.3-1.54c-.3-.36-.77-.36-1.07 0-.3.36-.3.95 0 1.31l1.83 2.17c.3.36.77.36 1.07 0l3.29-4.04c.3-.36.3-.95 0-1.31-.3-.36-.77-.36-1.07 0z" fill="currentColor"/>
        </svg>
        <time datetime="<%= date_xml(post.date) %>">
          <%= date(post.date, 'YYYY-MM-DD') %>
        </time>
      </span>
      
      <% if (config.features?.reading_time) { %>
        <span class="meta-item">
          <svg viewBox="0 0 24 24" width="14" height="14">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
          </svg>
          <span><%= Math.ceil(strip_html(post.content).length / 400) %> min read</span>
        </span>
      <% } %>
      
      <% if (post.tags && post.tags.length > 0) { %>
        <span class="meta-item">
          <svg viewBox="0 0 24 24" width="14" height="14">
            <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58s1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41s-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z" fill="currentColor"/>
          </svg>
          <span><%= post.tags.length %> tags</span>
        </span>
      <% } %>
    </div>
  </div>
</article>
