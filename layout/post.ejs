<%
// 文章页面布局
const config = theme;
const tocEnabled = config.toc?.enable !== false && page.toc;
%>

<!-- Reading Progress Bar -->
<% if (config.reading_progress?.enable) { %>
<div id="reading-progress" class="reading-progress" style="height: <%= config.reading_progress?.height || 3 %>px; background: <%= config.reading_progress?.color || '#4a90d9' %>;">
  <div class="reading-progress-bar"></div>
</div>
<% } %>

<!-- Article Container -->
<div class="article-container">
  <!-- Article Header -->
  <div class="article-header">
    <h1 class="article-title"><%= page.title %></h1>

    <div class="article-meta">
      <span class="meta-item">
        <svg class="icon" viewBox="0 0 24 24" width="16" height="16">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.3-1.54c-.3-.36-.77-.36-1.07 0-.3.36-.3.95 0 1.31l1.83 2.17c.3.36.77.36 1.07 0l3.29-4.04c.3-.36.3-.95 0-1.31-.3-.36-.77-.36-1.07 0z" fill="currentColor"/>
        </svg>
        <time datetime="<%= date_xml(page.date) %>">
          <%= date(page.date, config.article?.date_format || 'YYYY-MM-DD') %>
        </time>
      </span>

      <% if (page.categories && page.categories.length > 0) { %>
        <span class="meta-item">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor"/>
          </svg>
          <% page.categories.forEach((cat, idx) => { %>
            <a href="<%= url_for(cat.path) %>"><%= cat.name %></a><% if (idx < page.categories.length - 1) { %>, <% } %>
          <% }); %>
        </span>
      <% } %>

      <% if (config.features?.reading_time) { %>
        <span class="meta-item">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
          </svg>
          <span id="reading-time">--</span> min read
        </span>
      <% } %>

      <% if (config.features?.word_count) { %>
        <span class="meta-item word-count">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16">
            <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="currentColor"/>
          </svg>
          <span id="word-count">--</span> words
        </span>
      <% } %>
    </div>

    <% if (page.tags && page.tags.length > 0) { %>
      <div class="article-tags">
        <svg class="icon" viewBox="0 0 24 24" width="14" height="14">
          <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z" fill="currentColor"/>
        </svg>
        <% page.tags.forEach(tag => { %>
          <a href="<%= url_for(tag.path) %>" class="tag"><%= tag.name %></a>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Article Body with Optional TOC -->
  <div class="article-body<%= tocEnabled ? ' has-toc' : '' %>">
    <% if (tocEnabled && config.toc?.position !== 'left') { %>
      <%- partial('_partial/toc', { toc: page.toc }) %>
    <% } %>

    <!-- Main Content -->
    <article class="article-content">
      <%- page.content %>
    </article>

    <% if (tocEnabled && config.toc?.position === 'left') { %>
      <%- partial('_partial/toc', { toc: page.toc }) %>
    <% } %>
  </div>

  <!-- Article Footer -->
  <div class="article-footer">
    <% if (page.updated && config.article?.show_updated) { %>
      <div class="updated-info">
        <svg class="icon" viewBox="0 0 24 24" width="14" height="14">
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
        </svg>
        <%= __('updated') %>: <time datetime="<%= date_xml(page.updated) %>"><%= date(page.updated, config.article?.date_format || 'YYYY-MM-DD') %></time>
      </div>
    <% } %>

    <!-- Copyright -->
    <% if (config.copyright?.enable !== false) { %>
      <div class="article-copyright">
        <p><%= __('copyright_notice') %></p>
      </div>
    <% } %>

    <!-- Post Navigation -->
    <%- partial('_partial/post-nav') %>

    <!-- Reward -->
    <% if (config.donate?.enable) { %>
      <%- partial('_partial/donate') %>
    <% } %>
  </div>

  <!-- Comments -->
  <% if (config.features?.comments) { %>
    <div class="comments-wrapper">
      <%- partial('_partial/comments') %>
    </div>
  <% } %>
</div>
