// ============================================================
// Code Highlight Styles
// ============================================================

// Code block styles
pre
  background-color var(--color-code-bg)
  color var(--color-code-text)
  padding $space-lg
  border-radius $border-radius-lg
  overflow-x auto
  margin $space-lg 0
  line-height $line-height-normal
  font-family $font-family-code
  font-size $font-size-sm
  border 1px solid var(--color-border)
  smooth-transition()

code
  font-family $font-family-code
  font-size $font-size-sm
  background-color var(--color-code-bg)
  color var(--color-code-text)
  padding 2px 6px
  border-radius $border-radius-sm
  smooth-transition()

pre code
  background-color transparent
  color inherit
  padding 0
  border-radius 0

// Inline code
p code
  background-color var(--color-code-bg)
  padding 2px 6px
  border-radius $border-radius-sm

// Code line numbers
.line-number
  display inline-block
  width 2.5em
  text-align right
  padding-right $space-sm
  margin-right $space-sm
  color var(--color-text-secondary)
  user-select none
  border-right 1px solid var(--color-border)

// Code copy button
.code-copy-btn
  position absolute
  top $space-sm
  right $space-sm
  padding $space-sm $space-md
  background-color var(--color-hover-bg)
  color var(--color-text)
  border none
  border-radius $border-radius-md
  cursor pointer
  font-size $font-size-xs
  opacity 0
  smooth-transition()
  z-index 10

pre:hover .code-copy-btn
  opacity 1

.code-copy-btn:hover
  background-color $color-primary
  color white

.code-copy-btn.copied
  background-color $color-success
  color white

// Syntax highlighting colors
.hljs-keyword
  color var(--color-code-keyword)
  font-weight $font-weight-semibold

.hljs-string
  color var(--color-code-string)

.hljs-number
  color var(--color-code-number)

.hljs-literal
  color var(--color-code-number)

.hljs-attr
  color var(--color-code-keyword)

.hljs-comment
  color var(--color-code-comment)
  font-style italic

.hljs-title
  color var(--color-code-keyword)
  font-weight $font-weight-semibold

.hljs-function
  color var(--color-code-keyword)

.hljs-params
  color var(--color-code-text)

.hljs-built_in
  color var(--color-code-keyword)

.hljs-type
  color var(--color-code-keyword)

.hljs-variable
  color var(--color-code-text)

.hljs-symbol
  color var(--color-code-number)

.hljs-bullet
  color var(--color-code-number)

.hljs-link
  color $color-primary

.hljs-meta
  color var(--color-code-comment)

.hljs-selector-id
  color var(--color-code-keyword)

.hljs-selector-class
  color var(--color-code-keyword)

.hljs-selector-attr
  color var(--color-code-keyword)

.hljs-selector-pseudo
  color var(--color-code-keyword)

.hljs-template-tag
  color var(--color-code-keyword)

.hljs-template-variable
  color var(--color-code-text)

.hljs-addition
  background-color rgba(40, 167, 69, 0.1)
  color $color-success

.hljs-deletion
  background-color rgba(220, 53, 69, 0.1)
  color $color-danger

// Responsive code block
@media (max-width: $breakpoint-md)
  pre
    padding $space-md
    font-size $font-size-xs
    margin $space-md 0

  code
    font-size $font-size-xs

  .code-copy-btn
    opacity 1
    top 4px
    right 4px
    padding 4px 8px
    font-size 11px

// ============================================================
// Code Block Wrapper - Enhanced
// ============================================================

.code-block-wrapper
  position relative
  margin $spacing-lg 0

.code-block-header
  display flex
  justify-content space-between
  align-items center
  padding $padding-sm $padding-md
  background var(--color-bg-secondary)
  border 1px solid var(--color-border)
  border-bottom none
  border-radius $border-radius-lg $border-radius-lg 0 0

.code-lang
  font-size $font-size-xs
  font-weight $font-weight-medium
  color var(--color-text-secondary)
  font-family $font-family-code

.code-copy-btn
  position relative
  top auto
  right auto
  padding $padding-xs $padding-sm
  background transparent
  color var(--color-text-secondary)
  border 1px solid var(--color-border)
  border-radius $border-radius-sm
  cursor pointer
  font-size $font-size-xs
  opacity 1
  transition all 0.2s

.code-copy-btn:hover
  background var(--color-primary)
  border-color var(--color-primary)
  color white

.code-copy-btn.copied
  background $color-success
  border-color $color-success
  color white

// Remove old code block styles (use wrapper instead)
.code-block-wrapper pre
  margin 0
  border-radius 0 0 $border-radius-lg $border-radius-lg
  border-top none

// Mobile styles for code block
@media (max-width: $breakpoint-md)
  .code-block-header
    padding $padding-xs $padding-sm

  .code-lang
    font-size 11px

  .code-copy-btn
    padding 2px 6px
    font-size 11px

</content>
</invoke>