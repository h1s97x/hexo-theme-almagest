// ============================================================
// Dark Theme
// ============================================================

[data-theme="dark"]
  // Background Colors
  --color-bg: #1a1a1a
  --color-bg-secondary: #2d2d2d
  --color-hover-bg: #3a3a3a
  
  // Text Colors
  --color-text: #e8e8e8
  --color-text-secondary: #a0a0a0
  --color-text-tertiary: #707070
  
  // Border Colors
  --color-border: #404040
  --color-border-light: #353535
  
  // Code Colors
  --color-code-bg: #2d2d2d
  --color-code-text: #e8e8e8
  --color-code-keyword: #6db3f2
  --color-code-string: #6ddc6d
  --color-code-comment: #808080
  --color-code-number: #ff9d76
  
  // Table Colors
  --color-table-header-bg: #2d2d2d
  --color-table-row-hover: #3a3a3a
  --color-table-border: #404040
  
  // Input Colors
  --color-input-bg: #2d2d2d
  --color-input-border: #404040
  --color-input-focus: #6db3f2
  
  // Tag Colors
  --color-tag-bg: #1a3a5c
  --color-tag-text: #6db3f2
  
  // Link Colors
  --color-link: #6db3f2
  --color-link-hover: #8ac5f5
  --color-link-active: #5a9fe0
  
  // Button Colors
  --color-button-primary-bg: #0066cc
  --color-button-primary-text: #ffffff
  --color-button-primary-hover: #3385dd
  
  // Alert Colors
  --color-alert-success-bg: #1a3a1a
  --color-alert-success-text: #6ddc6d
  --color-alert-warning-bg: #3a3a1a
  --color-alert-warning-text: #ffc107
  --color-alert-danger-bg: #3a1a1a
  --color-alert-danger-text: #ff6b6b
  --color-alert-info-bg: #1a3a3a
  --color-alert-info-text: #6db3f2
  
  // Shadow Colors
  --color-shadow: rgba(0, 0, 0, 0.3)
  --color-shadow-dark: rgba(0, 0, 0, 0.5)

// ============================================================
// Dark Theme Specific Styles
// ============================================================

@media (prefers-color-scheme: dark)
  :root:not([data-theme])
    // Background Colors
    --color-bg: #1a1a1a
    --color-bg-secondary: #2d2d2d
    --color-hover-bg: #3a3a3a
    
    // Text Colors
    --color-text: #e8e8e8
    --color-text-secondary: #a0a0a0
    --color-text-tertiary: #707070
    
    // Border Colors
    --color-border: #404040
    --color-border-light: #353535
    
    // Code Colors
    --color-code-bg: #2d2d2d
    --color-code-text: #e8e8e8
    --color-code-keyword: #6db3f2
    --color-code-string: #6ddc6d
    --color-code-comment: #808080
    --color-code-number: #ff9d76
    
    // Table Colors
    --color-table-header-bg: #2d2d2d
    --color-table-row-hover: #3a3a3a
    --color-table-border: #404040
    
    // Input Colors
    --color-input-bg: #2d2d2d
    --color-input-border: #404040
    --color-input-focus: #6db3f2
    
    // Tag Colors
    --color-tag-bg: #1a3a5c
    --color-tag-text: #6db3f2
    
    // Link Colors
    --color-link: #6db3f2
    --color-link-hover: #8ac5f5
    --color-link-active: #5a9fe0
    
    // Button Colors
    --color-button-primary-bg: #0066cc
    --color-button-primary-text: #ffffff
    --color-button-primary-hover: #3385dd
    
    // Alert Colors
    --color-alert-success-bg: #1a3a1a
    --color-alert-success-text: #6ddc6d
    --color-alert-warning-bg: #3a3a1a
    --color-alert-warning-text: #ffc107
    --color-alert-danger-bg: #3a1a1a
    --color-alert-danger-text: #ff6b6b
    --color-alert-info-bg: #1a3a3a
    --color-alert-info-text: #6db3f2
    
    // Shadow Colors
    --color-shadow: rgba(0, 0, 0, 0.3)
    --color-shadow-dark: rgba(0, 0, 0, 0.5)

// ============================================================
// Dark Theme Component Styles
// ============================================================

[data-theme="dark"]
  // Links
  a
    color: var(--color-link)
    
    &:hover
      color: var(--color-link-hover)
    
    &:active
      color: var(--color-link-active)
  
  // Buttons
  button
  .button
    background-color: var(--color-button-primary-bg)
    color: var(--color-button-primary-text)
    
    &:hover
      background-color: var(--color-button-primary-hover)
  
  // Code blocks
  code
  pre
    background-color: var(--color-code-bg)
    color: var(--color-code-text)
  
  // Tables
  table
    border-color: var(--color-table-border)
    
    thead
      background-color: var(--color-table-header-bg)
    
    tbody tr:hover
      background-color: var(--color-table-row-hover)
  
  // Inputs
  input
  select
  textarea
    background-color: var(--color-input-bg)
    border-color: var(--color-input-border)
    color: var(--color-text)
    
    &:focus
      border-color: var(--color-input-focus)
      box-shadow: 0 0 0 3px rgba(109, 179, 242, 0.1)
  
  // Tags
  .tag
    background-color: var(--color-tag-bg)
    color: var(--color-tag-text)
  
  // Alerts
  .alert
    &.alert-success
      background-color: var(--color-alert-success-bg)
      color: var(--color-alert-success-text)
    
    &.alert-warning
      background-color: var(--color-alert-warning-bg)
      color: var(--color-alert-warning-text)
    
    &.alert-danger
      background-color: var(--color-alert-danger-bg)
      color: var(--color-alert-danger-text)
    
    &.alert-info
      background-color: var(--color-alert-info-bg)
      color: var(--color-alert-info-text)
  
  // Blockquotes
  blockquote
    background-color: var(--color-bg-secondary)
    border-left-color: var(--color-link)
    color: var(--color-text-secondary)
  
  // Cards
  .card
    background-color: var(--color-bg)
    border-color: var(--color-border)
    box-shadow: 0 1px 3px var(--color-shadow)

</content>
