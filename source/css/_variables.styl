// Hexo Theme Almagest - Design Variables (Starry Night Theme)
// ======================================

// ============================================
// Starry Night Color Palette
// ============================================

// Deep Space Colors (for dark theme background)
$space-void = #0a0a12
$space-deep = #0d0d1a
$space-dark = #1a1a2e
$space-medium = #16213e
$space-light = #0f3460
$nebula-purple = #2a1a48
$nebula-blue = #1a1a3e

// Star Colors
$star-white = #ffffff
$star-blue = #6db3f2
$star-gold = #ffd700
$star-silver = #c0c0c0
$star-cyan = #00d4ff

// Accent Colors (constellation-inspired)
$constellation-blue = #4a90d9
$constellation-purple = #8b5cf6
$constellation-cyan = #06b6d4
$constellation-pink = #ec4899
$constellation-amber = #f59e0b

// Light Theme Colors
$light-bg-primary = #fafbfc
$light-bg-secondary = #f0f4f8
$light-bg-tertiary = #e8ecf0
$light-text-primary = #1a1a2e
$light-text-secondary = #4a5568
$light-text-tertiary = #718096
$light-border = #d1dce5
$light-divider = #e2e8f0

// Dark Theme Colors (Enhanced Starry Night)
$dark-bg-primary = #0a0e17
$dark-bg-secondary = #12162a
$dark-bg-tertiary = #1a1f3a
$dark-text-primary = #e8ecf4
$dark-text-secondary = #a0aec0
$dark-text-tertiary = #6b7a90
$dark-border = #2d3748
$dark-divider = #1e2433

// Primary Accent (Star Blue)
$primary-color = #4a90d9
$primary-light = #6db3f2
$primary-dark = #2a6cb0

// Secondary Colors
$secondary-color = #8b5cf6
$secondary-light = #a78bfa
$secondary-dark = #7c3aed

// Semantic Colors
$success-color = #10b981
$warning-color = #f59e0b
$danger-color = #ef4444
$info-color = #06b6d4

// Code Highlight Colors
$code-bg = #f5f5f5
$code-text = #333333
$code-keyword = #0066cc
$code-string = #28a745
$code-comment = #999999
$code-number = #ff6600

// ============================================
// Font Variables
// ============================================

// Font Families
$font-family-base = -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif
$font-family-heading = $font-family-base
$font-family-code = 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', 'source-code-pro', monospace
$font-family-serif = 'Georgia', 'Garamond', 'Times New Roman', serif

// Font Sizes
$font-size-base = 16px
$font-size-sm = 14px
$font-size-xs = 12px
$font-size-lg = 18px
$font-size-xl = 20px
$font-size-2xl = 24px
$font-size-3xl = 28px
$font-size-4xl = 32px

// Font Weights
$font-weight-light = 300
$font-weight-normal = 400
$font-weight-medium = 500
$font-weight-semibold = 600
$font-weight-bold = 700
$font-weight-extrabold = 800

// Line Heights
$line-height-tight = 1.2
$line-height-normal = 1.5
$line-height-relaxed = 1.75
$line-height-loose = 2

// Letter Spacing
$letter-spacing-tight = -0.02em
$letter-spacing-normal = 0
$letter-spacing-wide = 0.02em
$letter-spacing-wider = 0.05em

// ============================================
// Spacing Variables
// ============================================

// Base Spacing Unit (1rem = 16px)
$spacing-unit = 1rem

// Spacing Scale
$spacing-xs = 0.25rem    // 4px
$spacing-sm = 0.5rem     // 8px
$spacing-md = 1rem       // 16px
$spacing-lg = 1.5rem     // 24px
$spacing-xl = 2rem       // 32px
$spacing-2xl = 3rem      // 48px
$spacing-3xl = 4rem      // 64px
$spacing-4xl = 6rem      // 96px

// Padding
$padding-xs = $spacing-xs
$padding-sm = $spacing-sm
$padding-md = $spacing-md
$padding-lg = $spacing-lg
$padding-xl = $spacing-xl

// Margin
$margin-xs = $spacing-xs
$margin-sm = $spacing-sm
$margin-md = $spacing-md
$margin-lg = $spacing-lg
$margin-xl = $spacing-xl

// Gap (for flexbox/grid)
$gap-xs = $spacing-xs
$gap-sm = $spacing-sm
$gap-md = $spacing-md
$gap-lg = $spacing-lg
$gap-xl = $spacing-xl

// ============================================
// Border Variables
// ============================================

$border-radius-sm = 4px
$border-radius-md = 8px
$border-radius-lg = 12px
$border-radius-xl = 16px
$border-radius-full = 9999px

$border-width-thin = 1px
$border-width-normal = 2px
$border-width-thick = 3px

// ============================================
// Shadow Variables
// ============================================

$shadow-sm = 0 1px 2px 0 rgba(0, 0, 0, 0.05)
$shadow-md = 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)
$shadow-lg = 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)
$shadow-xl = 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)

// ============================================
// Transition Variables
// ============================================

$transition-fast = 150ms ease-in-out
$transition-base = 250ms ease-in-out
$transition-slow = 350ms ease-in-out

// ============================================
// Breakpoint Variables
// ============================================

$breakpoint-xs = 0
$breakpoint-sm = 576px
$breakpoint-md = 768px
$breakpoint-lg = 992px
$breakpoint-xl = 1200px
$breakpoint-2xl = 1400px

// ============================================
// Z-Index Variables
// ============================================

$z-index-dropdown = 1000
$z-index-sticky = 1020
$z-index-fixed = 1030
$z-index-modal-backdrop = 1040
$z-index-modal = 1050
$z-index-popover = 1060
$z-index-tooltip = 1070

// ============================================
// Container Variables
// ============================================

$container-width-sm = 540px
$container-width-md = 720px
$container-width-lg = 960px
$container-width-xl = 1140px
$container-width-2xl = 1320px

// ============================================
// Animation Variables
// ============================================

$animation-duration-fast = 150ms
$animation-duration-base = 250ms
$animation-duration-slow = 350ms

$animation-timing-ease-in = ease-in
$animation-timing-ease-out = ease-out
$animation-timing-ease-in-out = ease-in-out
$animation-timing-linear = linear
