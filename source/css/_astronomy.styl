// Astronomy Theme Styles
// Starry background and astronomy-themed components

// Starry background
.starry-background
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  background: linear-gradient(135deg, #0a0e27 0%, #1a1a3e 50%, #0f1a2e 100%)
  z-index: -1
  pointer-events: none
  
  &::before
    content: ''
    position: absolute
    width: 100%
    height: 100%
    background-image: 
      radial-gradient(1px 1px at 20px 30px, #eee, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 60px 70px, #fff, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 50px 50px, #ddd, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 130px 80px, #fff, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 90px 10px, #eee, rgba(0,0,0,0))
    background-repeat: repeat
    background-size: 200px 200px
    animation: twinkle 5s infinite

@keyframes twinkle
  0%, 100%
    opacity: 0.5
  50%
    opacity: 1

// Astronomy card component
.astronomy-card
  background: rgba(255, 255, 255, 0.05)
  border: 1px solid rgba(255, 255, 255, 0.1)
  border-radius: 8px
  padding: 1.5rem
  backdrop-filter: blur(10px)
  transition: all 0.3s ease
  
  &:hover
    background: rgba(255, 255, 255, 0.08)
    border-color: rgba(255, 255, 255, 0.2)
    transform: translateY(-2px)
  
  .astronomy-card-header
    display: flex
    align-items: center
    margin-bottom: 1rem
    
    .astronomy-card-icon
      font-size: 2rem
      margin-right: 1rem
      
    .astronomy-card-title
      font-size: 1.25rem
      font-weight: 600
      margin: 0
      color: #fff
  
  .astronomy-card-body
    color: rgba(255, 255, 255, 0.8)
    line-height: 1.6
    
    p
      margin: 0.5rem 0
  
  .astronomy-card-footer
    margin-top: 1rem
    padding-top: 1rem
    border-top: 1px solid rgba(255, 255, 255, 0.1)
    font-size: 0.875rem
    color: rgba(255, 255, 255, 0.6)

// Constellation navigation
.constellation-nav
  display: grid
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr))
  gap: 1rem
  margin: 2rem 0
  
  .constellation-item
    position: relative
    aspect-ratio: 1
    border-radius: 8px
    overflow: hidden
    cursor: pointer
    transition: all 0.3s ease
    background: rgba(255, 255, 255, 0.05)
    border: 1px solid rgba(255, 255, 255, 0.1)
    display: flex
    align-items: center
    justify-content: center
    flex-direction: column
    
    &:hover
      background: rgba(255, 255, 255, 0.1)
      border-color: rgba(255, 255, 255, 0.3)
      transform: scale(1.05)
    
    &.active
      background: rgba(100, 200, 255, 0.2)
      border-color: rgba(100, 200, 255, 0.5)
    
    .constellation-icon
      font-size: 2rem
      margin-bottom: 0.5rem
    
    .constellation-name
      font-size: 0.875rem
      font-weight: 500
      text-align: center
      color: rgba(255, 255, 255, 0.9)

// Astronomy event calendar
.astronomy-calendar
  background: rgba(255, 255, 255, 0.05)
  border: 1px solid rgba(255, 255, 255, 0.1)
  border-radius: 8px
  padding: 1.5rem
  backdrop-filter: blur(10px)
  
  .calendar-header
    display: flex
    justify-content: space-between
    align-items: center
    margin-bottom: 1.5rem
    
    h3
      margin: 0
      color: #fff
    
    .calendar-nav
      display: flex
      gap: 0.5rem
      
      button
        background: rgba(255, 255, 255, 0.1)
        border: 1px solid rgba(255, 255, 255, 0.2)
        color: #fff
        padding: 0.5rem 1rem
        border-radius: 4px
        cursor: pointer
        transition: all 0.2s ease
        
        &:hover
          background: rgba(255, 255, 255, 0.2)
  
  .calendar-grid
    display: grid
    grid-template-columns: repeat(7, 1fr)
    gap: 0.5rem
    
    .calendar-day-header
      text-align: center
      font-weight: 600
      color: rgba(255, 255, 255, 0.7)
      padding: 0.5rem
      font-size: 0.875rem
    
    .calendar-day
      aspect-ratio: 1
      display: flex
      align-items: center
      justify-content: center
      background: rgba(255, 255, 255, 0.05)
      border: 1px solid rgba(255, 255, 255, 0.1)
      border-radius: 4px
      cursor: pointer
      transition: all 0.2s ease
      color: rgba(255, 255, 255, 0.8)
      font-size: 0.875rem
      
      &:hover
        background: rgba(255, 255, 255, 0.1)
        border-color: rgba(255, 255, 255, 0.3)
      
      &.has-event
        background: rgba(100, 200, 255, 0.2)
        border-color: rgba(100, 200, 255, 0.5)
        font-weight: 600
      
      &.today
        background: rgba(255, 150, 100, 0.2)
        border-color: rgba(255, 150, 100, 0.5)
  
  .calendar-events
    margin-top: 1.5rem
    padding-top: 1.5rem
    border-top: 1px solid rgba(255, 255, 255, 0.1)
    
    .event-item
      padding: 0.75rem
      margin-bottom: 0.5rem
      background: rgba(100, 200, 255, 0.1)
      border-left: 3px solid rgba(100, 200, 255, 0.5)
      border-radius: 4px
      
      .event-name
        font-weight: 600
        color: #fff
        margin-bottom: 0.25rem
      
      .event-time
        font-size: 0.875rem
        color: rgba(255, 255, 255, 0.6)

// Observation guide
.observation-guide
  background: rgba(255, 255, 255, 0.05)
  border: 1px solid rgba(255, 255, 255, 0.1)
  border-radius: 8px
  padding: 1.5rem
  backdrop-filter: blur(10px)
  
  .guide-header
    margin-bottom: 1.5rem
    
    h3
      margin: 0 0 0.5rem 0
      color: #fff
    
    .guide-location
      font-size: 0.875rem
      color: rgba(255, 255, 255, 0.6)
  
  .guide-section
    margin-bottom: 1.5rem
    
    h4
      color: rgba(255, 255, 255, 0.9)
      margin: 0 0 0.75rem 0
      font-size: 1rem
    
    .guide-content
      color: rgba(255, 255, 255, 0.8)
      line-height: 1.6
      
      ul, ol
        margin: 0.5rem 0
        padding-left: 1.5rem
        
        li
          margin-bottom: 0.5rem
  
  .guide-tips
    background: rgba(255, 200, 100, 0.1)
    border-left: 3px solid rgba(255, 200, 100, 0.5)
    padding: 1rem
    border-radius: 4px
    margin-top: 1rem
    
    .tips-title
      font-weight: 600
      color: rgba(255, 200, 100, 0.9)
      margin-bottom: 0.5rem
    
    .tips-content
      color: rgba(255, 255, 255, 0.8)
      font-size: 0.875rem

// Astronomy theme integration
body.astronomy-theme
  background: linear-gradient(135deg, #0a0e27 0%, #1a1a3e 50%, #0f1a2e 100%)
  color: rgba(255, 255, 255, 0.9)
  
  .main-content
    background: rgba(255, 255, 255, 0.02)
  
  a
    color: rgba(100, 200, 255, 0.9)
    
    &:hover
      color: rgba(100, 200, 255, 1)

// Responsive adjustments
@media (max-width: 768px)
  .constellation-nav
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr))
  
  .astronomy-card
    padding: 1rem
  
  .calendar-grid
    gap: 0.25rem
    
    .calendar-day
      font-size: 0.75rem
