// Hexo Theme Almagest - Extra Components Styles
// ==============================================

// ============================================
// Mermaid - 图表样式
// ============================================

.mermaid
  text-align: center
  padding: $spacing-lg
  background: var(--color-bg)
  border-radius: $border-radius-md
  margin: $spacing-lg 0

  svg
    max-width: 100%
    height: auto

// Mermaid 错误提示
.mermaid-error
  color: #cc0000
  font-size: $font-size-sm
  padding: $spacing-md
  background: rgba(#cc0000, 0.1)
  border-radius: $border-radius-sm
  margin: $spacing-md 0

// ============================================
// KaTeX - 数学公式样式
// ============================================

// KaTeX 公式显示优化
.katex-display
  overflow-x: auto
  overflow-y: hidden
  padding: $spacing-md 0

  // 防止公式换行导致布局问题
  table
    display: inline-table

// KaTeX 错误样式
.katex-error
  color: #cc0000
  font-family: monospace

// 复制 KaTeX 按钮
.copy-tex
  position: absolute
  top: 0
  right: 0
  padding: 4px 8px
  font-size: 12px
  color: $light-text-tertiary
  background: transparent
  border: none
  cursor: pointer
  opacity: 0
  transition: opacity 0.2s

  &:hover
    color: $primary-color

.katex-block:hover .copy-tex,
.hover\\:show:hover .copy-tex
  opacity: 1

body.dark-theme
  .copy-tex
    color: $dark-text-tertiary

    &:hover
      color: $primary-light

// ============================================
// Medium Zoom - 图片灯箱
// ============================================

.zoom-overlay
  cursor: zoom-out

.zoom-image
  cursor: zoom-out

// 缩放动画
img.zoomable
  cursor: zoom-in
  transition: transform 0.2s ease

  &:hover
    transform: scale(1.02)

// ============================================
// Reading Progress Bar
// ============================================

.reading-progress
  position: fixed
  top: 0
  left: 0
  width: 100%
  z-index: $z-index-fixed
  overflow: hidden

  .reading-progress-bar
    height: 100%
    width: 0
    transition: width 0.1s ease

// ============================================
// Table of Contents (TOC)
// ============================================

.toc-wrapper
  position: sticky
  top: $spacing-xl
  max-height: calc(100vh - #{$spacing-xl * 2})
  background: $light-bg-secondary
  border-radius: $border-radius-lg
  padding: $padding-lg
  overflow-y: auto
  font-size: $font-size-sm

  &.toc-right
    order: 2
    margin-left: $spacing-xl

  &.toc-left
    order: 0
    margin-right: $spacing-xl

  .toc-header
    display: flex
    align-items: center
    justify-content: space-between
    margin-bottom: $spacing-md

    .toc-title
      display: flex
      align-items: center
      gap: $spacing-sm
      font-size: $font-size-base
      font-weight: $font-weight-semibold
      color: $light-text-primary
      margin: 0

      svg
        width: 18px
        height: 18px
        color: $primary-color

    .toc-toggle
      background: none
      border: none
      cursor: pointer
      color: $light-text-tertiary
      padding: 0
      transition: transform $transition-base

      svg
        width: 16px
        height: 16px

  .toc-content
    .toc-list
      list-style: none
      padding: 0
      margin: 0

      li
        margin-bottom: $spacing-xs

      a
        display: block
        padding: $padding-xs $padding-sm
        color: $light-text-secondary
        text-decoration: none
        border-left: 2px solid transparent
        transition: all $transition-base

        &:hover
          color: $primary-color
          border-left-color: $primary-color

        &.active
          color: $primary-color
          border-left-color: $primary-color
          font-weight: $font-weight-medium

    .toc-list-number
      counter-reset: toc-counter

      li
        counter-increment: toc-counter

        a::before
          content: counter(toc-counter) ". "
          color: $light-text-tertiary

  &.collapsed .toc-content
    display: none

body.dark-theme
  .toc-wrapper
    background: $dark-bg-secondary

    .toc-title
      color: $dark-text-primary

    .toc-content a
      color: $dark-text-secondary

      &:hover
      &.active
        color: $primary-light
        border-left-color: $primary-light

// ============================================
// Post Navigation
// ============================================

.post-nav
  display: grid
  grid-template-columns: 1fr 1fr
  gap: $spacing-lg
  margin-top: $spacing-2xl
  padding-top: $spacing-xl
  border-top: 1px solid $light-divider

  .post-nav-prev
    text-align: left

  .post-nav-next
    text-align: right

  .nav-link
    display: inline-block
    padding: $padding-lg
    background: $light-bg-secondary
    border-radius: $border-radius-lg
    text-decoration: none
    transition: all $transition-base

    &:hover
      background: rgba($primary-color, 0.1)

      .nav-title
        color: $primary-color

    .nav-label
      display: flex
      align-items: center
      gap: $spacing-xs
      font-size: $font-size-xs
      color: $light-text-tertiary
      margin-bottom: $spacing-xs

      svg
        width: 14px
        height: 14px

    .nav-title
      font-size: $font-size-base
      font-weight: $font-weight-medium
      color: $light-text-primary
      transition: color $transition-base
      display: -webkit-box
      -webkit-line-clamp: 2
      -webkit-box-orient: vertical
      overflow: hidden

body.dark-theme
  .post-nav
    border-top-color: $dark-divider

    .nav-link
      background: $dark-bg-secondary

      &:hover
        background: rgba($primary-light, 0.1)

        .nav-title
          color: $primary-light

      .nav-label
        color: $dark-text-tertiary

      .nav-title
        color: $dark-text-primary

// ============================================
// Article Copyright
// ============================================

.article-copyright
  margin-top: $spacing-xl
  padding: $padding-lg
  background: rgba($primary-color, 0.05)
  border-left: 4px solid $primary-color
  border-radius: 0 $border-radius-md $border-radius-md 0
  font-size: $font-size-sm
  color: $light-text-secondary

body.dark-theme
  .article-copyright
    background: rgba($primary-light, 0.05)
    border-left-color: $primary-light
    color: $dark-text-secondary

// ============================================
// Article Image
// ============================================

.article-image
  margin: $spacing-xl 0

  img
    max-width: 100%
    height: auto
    border-radius: $border-radius-lg

  figcaption
    margin-top: $spacing-sm
    font-size: $font-size-sm
    color: $light-text-tertiary
    text-align: center

body.dark-theme
  .article-image figcaption
    color: $dark-text-tertiary

// ============================================
// Note Tags
// ============================================

.note
  margin: $spacing-lg 0
  padding: $padding-lg
  border-radius: $border-radius-md
  border-left: 4px solid

  .note-content
    p:last-child
      margin-bottom: 0

  &.note-default
    background: $light-bg-secondary
    border-left-color: $light-text-tertiary

  &.note-primary
    background: rgba(#4a90d9, 0.1)
    border-left-color: #4a90d9

  &.note-success
    background: rgba(#52c41a, 0.1)
    border-left-color: #52c41a

  &.note-warning
    background: rgba(#faad14, 0.1)
    border-left-color: #faad14

  &.note-danger
    background: rgba(#ff4d4f, 0.1)
    border-left-color: #ff4d4f

body.dark-theme
  .note
    &.note-default
      background: $dark-bg-secondary
      border-left-color: $dark-text-tertiary

    &.note-primary
      background: rgba($primary-light, 0.1)
      border-left-color: $primary-light

// ============================================
// Timeline
// ============================================

.timeline
  margin: $spacing-xl 0

  .timeline-title
    font-size: $font-size-lg
    font-weight: $font-weight-semibold
    color: $light-text-primary
    margin-bottom: $spacing-lg

  .timeline-content
    position: relative
    padding-left: $spacing-xl

    &::before
      content: ''
      position: absolute
      left: 6px
      top: 0
      bottom: 0
      width: 2px
      background: $light-divider

  .timeline-node
    position: relative
    margin-bottom: $spacing-lg

    &::before
      content: ''
      position: absolute
      left: -#{$spacing-xl + 3px}
      top: 6px
      width: 12px
      height: 12px
      background: $primary-color
      border-radius: 50%

    .timeline-node-title
      font-weight: $font-weight-semibold
      color: $light-text-primary
      margin-bottom: $spacing-xs

body.dark-theme
  .timeline
    .timeline-title
      color: $dark-text-primary

    .timeline-content::before
      background: $dark-divider

    .timeline-node::before
      background: $primary-light

    .timeline-node-title
      color: $dark-text-primary

// ============================================
// Folding/Collapse
// ============================================

.folding-block
  margin: $spacing-lg 0
  border: 1px solid $light-border
  border-radius: $border-radius-md
  overflow: hidden

  .folding-title
    display: flex
    align-items: center
    padding: $padding-md $padding-lg
    font-weight: $font-weight-medium
    color: $light-text-primary
    background: $light-bg-secondary
    cursor: pointer
    user-select: none

    &::before
      content: '▶'
      font-size: $font-size-xs
      margin-right: $spacing-sm
      transition: transform $transition-base

  &[open] .folding-title::before
    transform: rotate(90deg)

  .folding-content
    padding: $padding-lg
    border-top: 1px solid $light-border

body.dark-theme
  .folding-block
    border-color: $dark-border

    .folding-title
      color: $dark-text-primary
      background: $dark-bg-secondary

    .folding-content
      border-top-color: $dark-border

// ============================================
// Link Card
// ============================================

.link-card
  display: block
  margin: $spacing-lg 0
  padding: $padding-lg
  background: $light-bg-secondary
  border-radius: $border-radius-lg
  text-decoration: none
  transition: all $transition-base

  &:hover
    background: rgba($primary-color, 0.1)
    transform: translateY(-2px)

  .link-card-content
    .link-title
      font-size: $font-size-base
      font-weight: $font-weight-medium
      color: $light-text-primary
      margin-bottom: $spacing-xs

    .link-desc
      font-size: $font-size-sm
      color: $light-text-secondary
      margin-bottom: $spacing-sm

    .link-url
      font-size: $font-size-xs
      color: $light-text-tertiary

body.dark-theme
  .link-card
    background: $dark-bg-secondary

    &:hover
      background: rgba($primary-light, 0.1)

    .link-title
      color: $dark-text-primary

    .link-desc
      color: $dark-text-secondary

// ============================================
// Badge
// ============================================

.badge
  display: inline-flex
  align-items: center
  padding: $padding-xs $padding-sm
  font-size: $font-size-xs
  font-weight: $font-weight-medium
  border-radius: $border-radius-sm

  &.badge-default
    color: $light-text-secondary
    background: $light-bg-secondary

  &.badge-primary
    color: white
    background: $primary-color

  &.badge-success
    color: white
    background: #52c41a

  &.badge-warning
    color: white
    background: #faad14

  &.badge-danger
    color: white
    background: #ff4d4f

body.dark-theme
  .badge
    &.badge-default
      color: $dark-text-secondary
      background: $dark-bg-secondary

// ============================================
// Tabs - 多标签页切换
// ============================================

.tabs-wrapper
  margin: $spacing-lg 0
  border: 1px solid $light-border
  border-radius: $border-radius-md
  overflow: hidden

.tabs-nav
  display: flex
  flex-wrap: wrap
  background: $light-bg-secondary
  border-bottom: 1px solid $light-border
  padding: 0
  margin: 0

.tab-btn
  padding: $padding-md $padding-lg
  font-size: $font-size-sm
  font-weight: $font-weight-medium
  color: $light-text-secondary
  background: transparent
  border: none
  border-bottom: 2px solid transparent
  cursor: pointer
  transition: all $transition-base
  margin-bottom: -1px

  &:hover
    color: $primary-color

  &.active
    color: $primary-color
    border-bottom-color: $primary-color
    background: $light-bg-primary

.tabs-content
  .tab-pane
    display: none
    padding: $padding-lg

    &.active
      display: block

  // Preserve markdown content styling
  h1, h2, h3, h4, h5, h6
    margin-top: $spacing-lg
    margin-bottom: $spacing-md

  p, ul, ol, pre
    margin-bottom: $spacing-md

  p:last-child
    margin-bottom: 0

body.dark-theme
  .tabs-wrapper
    border-color: $dark-border

  .tabs-nav
    background: $dark-bg-secondary
    border-bottom-color: $dark-border

  .tab-btn
    color: $dark-text-secondary

    &:hover
      color: $primary-light

    &.active
      color: $primary-light
      background: $dark-bg-primary

// ============================================
// Gallery - 图片画廊
// ============================================

.gallery-wrapper
  display: grid
  grid-template-columns: repeat(var(--gallery-cols, 3), 1fr)
  gap: $spacing-md
  margin: $spacing-lg 0

  img
    width: 100%
    height: auto
    border-radius: $border-radius-md
    object-fit: cover
    transition: transform $transition-base

    &:hover
      transform: scale(1.02)

@media (max-width: 768px)
  .gallery-wrapper
    grid-template-columns: repeat(2, 1fr)

// ============================================
// Code Block Enhancement
// ============================================

.code-block-wrapper
  margin: $spacing-lg 0
  border-radius: $border-radius-md
  overflow: hidden
  background: $code-bg
  border: 1px solid $light-border

.code-block-header
  display: flex
  justify-content: space-between
  align-items: center
  padding: $padding-sm $padding-md
  background: darken($code-bg, 5%)
  border-bottom: 1px solid $light-border

  .code-lang
    font-size: $font-size-xs
    font-weight: $font-weight-medium
    color: $light-text-tertiary

.code-copy-btn
  padding: $padding-xs $padding-sm
  font-size: $font-size-xs
  color: $light-text-tertiary
  background: transparent
  border: 1px solid $light-border
  border-radius: $border-radius-sm
  cursor: pointer
  transition: all $transition-base

  &:hover
    color: $primary-color
    border-color: $primary-color

.code-block
  margin: 0
  padding: $padding-lg
  overflow-x: auto
  font-size: $font-size-sm
  line-height: $line-height-base

body.dark-theme
  .code-block-wrapper
    border-color: $dark-border

  .code-block-header
    background: lighten($code-bg-dark, 5%)

    .code-lang
      color: $dark-text-tertiary

  .code-copy-btn
    color: $dark-text-tertiary
    border-color: $dark-border

// ============================================
// Label Enhancement
// ============================================

.label
  display: inline
  padding: 2px 8px
  font-size: 0.875em
  font-weight: $font-weight-medium
  border-radius: $border-radius-sm
  background: $light-bg-secondary
  color: $light-text-primary

  &.label-primary
    background: rgba($primary-color, 0.15)
    color: $primary-color

  &.label-success
    background: rgba(#52c41a, 0.15)
    color: #52c41a

  &.label-warning
    background: rgba(#faad14, 0.15)
    color: #faad14

  &.label-danger
    background: rgba(#ff4d4f, 0.15)
    color: #ff4d4f

  &.label-info
    background: rgba(#1890ff, 0.15)
    color: #1890ff

body.dark-theme
  .label
    background: $dark-bg-secondary
    color: $dark-text-primary

    &.label-primary
      background: rgba($primary-light, 0.15)
      color: $primary-light

// ============================================
// Table Wrapper - 响应式表格
// ============================================

.table-wrapper
  overflow-x: auto
  margin: $spacing-lg 0
  border-radius: $border-radius-md
  border: 1px solid $light-border

  table
    margin: 0
    min-width: 100%

  // Preserve table styles from _components.styl
  th, td
    white-space: nowrap

body.dark-theme
  .table-wrapper
    border-color: $dark-border

// ============================================
// Video & Audio Player
// ============================================

.video-player,
.audio-player
  max-width: 100%
  margin: $spacing-lg 0
  border-radius: $border-radius-md

.video-player
  width: 100%
  height: auto

.audio-player
  width: 100%
  height: 40px

// ============================================
// Grid Layout
// ============================================

.grid-layout
  display: grid
  gap: $spacing-lg
  margin: $spacing-lg 0

  &.grid-cols-2
    grid-template-columns: repeat(2, 1fr)

  &.grid-cols-3
    grid-template-columns: repeat(3, 1fr)

  &.grid-cols-4
    grid-template-columns: repeat(4, 1fr)

@media (max-width: 768px)
  .grid-layout
    grid-template-columns: 1fr !important

// ============================================
// Text Align Wrapper
// ============================================

.align-wrapper
  margin: $spacing-lg 0

// ============================================
// Read Mode - 阅读模式
// ============================================

body.read-mode
  // 隐藏不必要的元素
  .sidebar,
  #header,
  #footer,
  .post-nav,
  .comments-wrapper,
  .toc-wrapper,
  #rightside-config-hide,
  .article-tags,
  .article-meta
    display: none !important

  // 调整内容宽度
  .main-content
    padding: 0

  .container
    max-width: 720px

  .article-container
    max-width: 720px
    margin: 0 auto
    padding: $spacing-2xl 0

  // 隐藏背景效果
  .starry-background,
  .bg-canvas
    display: none

  // 恢复阅读模式按钮
  #rightside-config-hide
    display: flex !important
    opacity: 1 !important
    visibility: visible !important
    transform: none !important

  // 阅读模式按钮样式
  .read-mode
    background: var(--color-primary)
    border-color: var(--color-primary)
    color: white

    &:hover
      background: var(--color-primary-dark)
      border-color: var(--color-primary-dark)
